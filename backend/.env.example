PORT=5000

# NeonDB PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/bidarena?sslmode=require

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Email (Nodemailer — use Gmail App Password or any SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=BIDArena <youremail@gmail.com>

# Frontend origin for CORS
CLIENT_ORIGIN=http://localhost:3000
